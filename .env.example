# Public app URL (used to build OAuth callback URL on Vercel)
APP_URL="https://your-app.vercel.app"

# OpenAI OAuth configuration
OPENAI_OAUTH_CLIENT_ID=""
OPENAI_OAUTH_CLIENT_SECRET=""
# Optional override values (defaults are already provided in API routes)
# OPENAI_OAUTH_AUTH_URL="https://auth.openai.com/oauth/authorize"
# OPENAI_OAUTH_TOKEN_URL="https://auth.openai.com/oauth/token"
# OPENAI_OAUTH_REDIRECT_URI="https://your-app.vercel.app/api/oauth-callback"
# OPENAI_OAUTH_SCOPE="openid profile email"

# Optional service-token fallback (if you also want non-OAuth server-side access)
# OPENAI_API_KEY=""

# OpenAI model selectors
OPENAI_TEXT_MODEL="gpt-4.1-mini"
OPENAI_IMAGE_MODEL="sora-1"
OPENAI_VIDEO_MODEL="sora-1"
OPENAI_VIDEO_DURATION_SECONDS="5"
OPENAI_VIDEO_RESOLUTION="720p"
